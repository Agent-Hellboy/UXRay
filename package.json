{
  "name": "uxray-ui-audit",
  "version": "0.1.0",
  "description": "CLI to audit a live web app UI for layout, accessibility, and UX issues",
  "main": "ui-review.js",
  "type": "commonjs",
  "bin": {
    "uxray": "ui-review.js"
  },
  "scripts": {
    "review": "node ui-review.js",
    "smoke": "node scripts/smoke.js",
    "ci": "npm run smoke"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agent-Hellboy/UXRay.git"
  },
  "keywords": [
    "ui",
    "ux",
    "playwright",
    "axe",
    "accessibility",
    "audit"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "playwright": "^1.59.1"
  }
}
